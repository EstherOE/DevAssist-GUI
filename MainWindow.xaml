<Window x:Class="DevAssistGU.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DevAssistGU"
        mc:Ignorable="d"
        Title="Dev tool" Height="350" Width="800"
Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="DevAssist"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>

            <Button Content="Help"
                    Click="ShowHelp"
                    Margin="20,0,0,0"
                    Padding="10,5"/>
     <Button Content="Clear"
                    Click="Clear"
                    Margin="20,0,0,0"
                    Padding="10,5"/>

        </StackPanel>

        <!-- OUTPUT -->
        <TextBox x:Name="OutputBox"
                 Grid.Row="1"
                 Background="#252526"
                 Foreground="White"
                 BorderThickness="0"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"/>

        <!-- INPUT AREA -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Grid.Column="0"
                     Background="#333333"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="8"
                     FontFamily="Consolas"
                     KeyDown="InputBox_KeyDown"/>

            <Button Content="Run"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Click="RunCommand"/>
        </Grid>

    </Grid>

  </Window>
